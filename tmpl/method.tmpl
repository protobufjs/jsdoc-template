<?js
const data = obj;
const self = this;
?>
<dt>
    <div class="nameContainer<?js if (data.inherited) { ?> inherited<?js } ?>">
        <h4 class="name" id="<?js= id ?>">
            <?js if (data.inherited || data.inherits) { ?>
                <span class="inherited"><?js= this.linkto(data.inherits, 'inherited') ?></span>
            <?js } ?>
            <?js= data.attribs + (kind === 'class' ? 'new ' : '') + (data.scope === 'static' ? longname : name) + (kind !== 'event' ? data.signature : '') ?>
        </h4>
    
        <?js if (data.meta) {?>
        <div class="tag-source">
            <?js= self.linkto(meta.filename) ?>, <?js= self.linkto(meta.filename, 'line ' + meta.lineno, null, 'L' + meta.lineno) ?>
        </div>
        <?js } ?>
    </div>

    <?js if (data.summary) { ?>
    <p class="summary"><?js= summary ?></p>
    <?js } ?>
</dt>
<dd>
    
    <?js if (data.description) { ?>
    <div class="description">
        <?js= data.description ?>
    </div>
    <?js } ?>

    <?js if (kind === 'event' && data.type && data.type.names) {?>
        <h5 class="subsection-title">Type:</h5>
        <ul>
            <li>
                <?js= self.partial('type.tmpl', data.type.names) ?>
            </li>
        </ul>
    <?js } ?>
    
    <?js if (data['this']) { ?>
        <h5 class="subsection-title">This:</h5>
        <ul class="detail-list"><li><?js= this.linkto(data['this'], data['this']) ?></li></ul>
    <?js } ?>
    
    <?js if (data.params && params.length) { ?>
        <h5 class="subsection-title">Parameters:</h5>
        <?js= this.partial('params.tmpl', params) ?>
    <?js } ?>
    
    <?js= this.partial('details.tmpl', data) ?>
    
    <?js if (data.fires && fires.length) { ?>
    <h5 class="subsection-title">Fires:</h5>
    <ul><?js fires.forEach(function(f) { ?>
        <li><?js= self.linkto(f) ?></li>
    <?js }); ?></ul>
    <?js } ?>

    <?js if (data.listens && listens.length) { ?>
    <h5 class="subsection-title">Listens to Events:</h5>
    <ul><?js listens.forEach(function(f) { ?>
        <li><?js= self.linkto(f) ?></li>
    <?js }); ?></ul>
    <?js } ?>

    <?js if (data.listeners && listeners.length) { ?>
    <h5 class="subsection-title">Listeners of This Event:</h5>
    <ul><?js listeners.forEach(function(f) { ?>
        <li><?js= self.linkto(f) ?></li>
    <?js }); ?></ul>
    <?js } ?>
    
    <?js if (data.exceptions && exceptions.length) { ?>
    <h5 class="subsection-title">Throws:</h5>
    <table class="params exception-table">
        <tbody>
    <?js exceptions.forEach(function(r) { ?>
        <?js= self.partial('exceptions.tmpl', r) ?>
    <?js }); ?>
        </tbody>
    </table>
    <?js } ?>
    
    <?js if (data.returns && returns.length) { ?>
    <h5 class="subsection-title">Returns:</h5>
    <?js= self.partial('returns.tmpl', data.returns) ?>
    <?js } ?>
    
    <?js if (data.examples && examples.length) { ?>
        <h5 class="subsection-title">Example<?js= examples.length > 1? 's':'' ?>:</h5>
        <?js= this.partial('examples.tmpl', examples) ?>
    <?js } ?>
</dd>
