<?js
const self = this;
const navSections = [
    { className: 'members', title: 'Members', key: 'members' },
    { className: 'typedefs', title: 'Typedefs', key: 'typedefs' },
    { className: 'methods', title: 'Methods', key: 'methods' },
    { className: 'events', title: 'Events', key: 'events' }
];
const navTypeTitles = {
    namespace: 'Namespaces',
    class: 'Classes',
    interface: 'Interfaces'
};
let currentNavType = null;
?>
<div class="navigation">
    <h3 class="applicationName"><a href="index.html"><?js= env.conf.templates.applicationName ?></a></h3>
    <p class="applicationSubtitle"><?js= env.conf.templates.applicationSubtitle || 'API documentation' ?></p>

    <div class="search">
        <input id="search" type="text" placeholder="Find a symbol">
    </div>
    <ul class="list">
        <li class="item" data-name="global">
            <span class="title">
                <?js= self.linkto("global", "Top Level") ?>
                <span class="static">static</span>
            </span>
        </li>
    <?js
    this.nav.forEach(function (item) {
        if (item.type !== currentNavType) {
            currentNavType = item.type;
            if (navTypeTitles[item.type]) {
    ?>
        <li class="item nav-section">
            <span class="subtitle"><?js= navTypeTitles[item.type] ?></span>
        </li>
    <?js
            }
        }
    ?>
        <li class="item" data-name="<?js= item.longname ?>">
            <span class="title">
                <?js= self.linkto(item.longname, item.longname) ?>
                <?js if (item.type === 'namespace') { ?>
                <span class="static">static</span>
                <?js } ?>
            </span>
            <?js
                navSections.forEach(function(section) {
                    const sectionItems = item[section.key];
            ?>
            <ul class="<?js= section.className ?> itemMembers">
                <?js if (sectionItems.length) { ?>
                <span class="subtitle"><?js= section.title ?></span>
                <?js sectionItems.forEach(function (v) { ?>
                    <li data-name="<?js= v.longname ?>"><?js= self.linkto(v.longname, v.name) ?></li>
                <?js }); ?>
                <?js } ?>
            </ul>
            <?js }); ?>
        </li>
    <?js }); ?>
    </ul>
</div>
