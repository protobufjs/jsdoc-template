<?js
const data = obj;
const self = this;
let typeSignature = '';

if (data.type && data.type.names) {
    data.type.names.forEach(function (name) {
        if (typeSignature)
            typeSignature += ' | ';
        typeSignature += self.mangleType(self.linkto(name, self.htmlsafe(name)));
    });
    typeSignature = '<span class="type-signature type">{ ' + typeSignature + ' }</span>';
}
?>
<dt>
    <div class="nameContainer">
        <h4 class="name" id="<?js= id ?>"><?js= (data.scope === 'static' ? longname : name) + " " + data.attribs + typeSignature ?></h4>
    </div>
    
    <?js if (data.summary) { ?>
    <p class="summary"><?js= summary ?></p>
    <?js } ?>
</dt>
<dd>
    <?js if (data.description) { ?>
    <div class="description">
        <?js= data.description ?>
    </div>
    <?js } ?>
    
    <?js= this.partial('details.tmpl', data) ?>
    
    <?js if (data.examples && examples.length) { ?>
        <h5>Example<?js= examples.length > 1? 's':'' ?></h5>
        <?js= this.partial('examples.tmpl', examples) ?>
    <?js } ?>
</dd>
